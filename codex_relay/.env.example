# Copia esto a .env (sin el .example) y rellena.
# .env NO se commitea — contiene secrets.

# Secret compartido entre tu Mac y la Netlify Function.
# Genéralo con: openssl rand -hex 32
RELAY_SECRET=

# Dominio ngrok reservado (opcional pero recomendado para que la URL no cambie)
# Sin esto, cada restart de ngrok genera una URL nueva y tienes que actualizar
# la env var CODEX_RELAY_URL en Netlify cada vez.
# Sácalo de https://dashboard.ngrok.com/domains → "Create domain"
# Ejemplo: blackwell-relay.ngrok.app
NGROK_DOMAIN=

# Puerto local del server (default 3411)
PORT=3411

# Comando de Codex CLI. Ajusta si tu binario está en otro path o se llama distinto.
# Para descubrir: which codex
CODEX_CMD=codex

# Args para invocar Codex en modo no-interactivo. Tienes que adaptar esto a tu
# versión exacta del CLI. Algunos ejemplos comunes:
#   exec --quiet          (versión clásica)
#   --print --no-tools    (algunas builds nuevas)
#   chat --noninteractive
# Si no sabes, prueba primero: codex --help
CODEX_ARGS=exec --quiet

# Cuánto esperamos al CLI antes de matarlo. 60s es generoso para Q&A.
CODEX_TIMEOUT_MS=60000
