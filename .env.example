# ─────────────────────────────────────────────────────────────────
# Blackwell — Variables de entorno
# Copia este archivo como .env (sin el .example) y rellena los valores.
# El archivo .env NO se sube a git — contiene credenciales privadas.
# ─────────────────────────────────────────────────────────────────

# ── Google Drive ──────────────────────────────────────────────────
# ID de la carpeta raíz "PROYECTOS BLACKWELL" en Google Drive
DRIVE_ROOT_FOLDER_ID=1lC48ni6Rg4e_uGtASQfC-QdBd3647LJ_

# Opción A — OAuth2 (para uso personal desde tu computadora)
# Descarga credentials.json desde:
# https://console.cloud.google.com → APIs → Credenciales → OAuth 2.0
GOOGLE_CREDENTIALS_PATH=credentials.json
GOOGLE_TOKEN_PATH=token.json

# Opción B — Service Account (para automatización en servidor)
# Crea una cuenta de servicio en Google Cloud y descarga el JSON de la clave.
# Deja vacío si usas OAuth2.
GOOGLE_SERVICE_ACCOUNT_JSON=

# OpenRouter (LLM diario WhatsApp)
# Necesaria para scripts/sync/wa_daily_analyzer.py.

OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-3.1-flash-lite
OPENROUTER_SITE_URL=https://github.com/BrandonBlackwell-ui/Sem-foro
OPENROUTER_APP_NAME=Blackwell Semaforo

# Monday.com (crear tareas desde action_items de WhatsApp)
# Necesaria para scripts/sync/wa_monday_tasks.py.
MONDAY_API_KEY=
MONDAY_TASKS_BOARD_ID=18418418634
MONDAY_TASKS_BOARD_NAME=WhatsApp Tasks
MONDAY_TASKS_STATUS_COLUMN_ID=color_mm452en1
MONDAY_TASKS_DUE_DATE_COLUMN_ID=date_mm45ncq9
MONDAY_TASKS_RESPONSIBLE_COLUMN_ID=multiple_person_mm453tee
MONDAY_TASKS_WORK_TYPE_COLUMN_ID=color_mm4513mj
# Columna "Grupo" en Monday. Visualmente son tags/labels de cliente.
MONDAY_TASKS_GROUP_COLUMN_ID=color_mm4ecz6r
# Alias viejo, se conserva por compatibilidad.
MONDAY_TASKS_CLIENT_COLUMN_ID=
# Pull Monday task status/responsible/date labels back into Supabase wa_tasks.
# Uses the same MONDAY_* variables above.

# ── Supabase (tareas por cliente → Monday) ────────────────────────
# Por defecto usa la misma instancia/llave publishable del dashboard.
# Solo definir si se cambia de proyecto Supabase.
# SUPABASE_URL=https://vrgjplbksqunkrblqjgj.supabase.co
# SUPABASE_KEY=sb_publishable_...

# ── Configuración del crawl ───────────────────────────────────────
# Profundidad máxima de recursión dentro de subfolders (default: 4)
CRAWL_MAX_DEPTH=4

# ── Configuración de staleness ────────────────────────────────────
# Re-verificar subfolders con más de N días sin verificar (default: 7)
STALE_MAX_AGE_DAYS=7

# Cuentas en onboarding con menos de N días: re-crawl semanal (default: 30)
ONBOARDING_FULL_RECRAWL_DAYS=30

# Máximo de subfolders a re-verificar por corrida (default: 40)
STALE_MAX_REVERIFY_PER_RUN=40
