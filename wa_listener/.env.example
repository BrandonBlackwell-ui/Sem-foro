# wa_listener/.env — Copia a .env y completa los valores
# El .env NO se sube a git (está en .gitignore)

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://vqgfkfvywbpjldreuplb.supabase.co

# service_role key (NO la anon key) — Supabase → Settings → API → service_role
# La service_role bypasa RLS y puede insertar en wa_messages
SUPABASE_SERVICE_KEY=eyJ...tu_service_role_key_aqui...

# Railway: create a persistent volume mounted at /data and set:
# AUTH_DIR=/data/auth_state
# Local default is ./auth_state if AUTH_DIR is omitted.
AUTH_DIR=

# Optional for Railway logs, where terminal QR can be hard to scan.
# Use digits only with country code, for example Mexico: 5215512345678
WA_PAIRING_PHONE_NUMBER=

# Optional: slows down Railway retries so pairing codes are not replaced too fast.
WA_PAIRING_RETRY_DELAY_MS=90000

# Optional: transcribe WhatsApp voice notes/audio before saving to Supabase.
# Keep the real key only in Railway variables or local .env, never in git.
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3
DEEPGRAM_LANGUAGE=es
MAX_TRANSCRIBE_AUDIO_BYTES=26214400
