# wa_listener/.env — Copia a .env y completa los valores
# El .env NO se sube a git (está en .gitignore)

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://vqgfkfvywbpjldreuplb.supabase.co

# service_role key (NO la anon key) — Supabase → Settings → API → service_role
# La service_role bypasa RLS y puede insertar en wa_messages
SUPABASE_SERVICE_KEY=eyJ...tu_service_role_key_aqui...

# Railway: create a persistent volume mounted at /data and set:
# AUTH_DIR=/data/auth_state
# Local default is ./auth_state if AUTH_DIR is omitted.
AUTH_DIR=
