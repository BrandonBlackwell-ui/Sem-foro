{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksConfigPath": "nixpacks.analyzer.toml"
  },
  "deploy": {
    "startCommand": "python scripts/sync/wa_daily_analyzer.py",
    "cronSchedule": "0 12 * * *",
    "restartPolicyType": "NEVER"
  }
}
